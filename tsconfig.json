{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "DOM",
            "ES2022"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "noEmit": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "useDefineForClassFields": true
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.d.ts"
    ]
}