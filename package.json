{
    "name": "tl-lincoln-bulk-export-helper",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "node ./scripts/build.mjs",
        "dev": "node ./scripts/build.mjs --watch",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "check": "npm run typecheck && npm run lint && npm run build",
        "chrome:debug": "pwsh -ExecutionPolicy Bypass -File ./scripts/open-chrome-debug.ps1",
        "chrome:debug:default-profile": "pwsh -ExecutionPolicy Bypass -File ./scripts/open-chrome-debug.ps1 -UseChromeUserData -ProfileDirectory Default",
        "chrome:debug:default-profile:resume": "pwsh -ExecutionPolicy Bypass -File ./scripts/open-chrome-debug.ps1 -UseChromeUserData -ProfileDirectory Default -RestoreLastSession",
        "chrome:profiles": "pwsh -ExecutionPolicy Bypass -File ./scripts/list-chrome-profiles.ps1",
        "chrome:pages": "node ./scripts/attach-chrome.mjs"
    },
    "devDependencies": {
        "@eslint/js": "^9.23.0",
        "@types/node": "^22.13.14",
        "@types/tampermonkey": "^5.0.4",
        "esbuild": "^0.25.1",
        "eslint": "^9.23.0",
        "globals": "^16.0.0",
        "playwright-core": "^1.52.0",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.28.0"
    }
}